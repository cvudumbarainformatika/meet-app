# =============================================================
# MeetApp — Environment Variables
# Copy file ini menjadi .env dan isi sesuai kebutuhan
# =============================================================

# -------------------------------------------------------
# APP
# -------------------------------------------------------
APP_ENV=development
APP_SECRET=changeme_secret_panjang_minimal_32karakter

# -------------------------------------------------------
# DATABASE (PostgreSQL)
# -------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=meetapp
POSTGRES_USER=meetapp
POSTGRES_PASSWORD=meetapp_pass

# -------------------------------------------------------
# REDIS
# -------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# -------------------------------------------------------
# LIVEKIT SERVER
# -------------------------------------------------------
LIVEKIT_HOST=livekit
LIVEKIT_PORT=7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret_panjang_minimal_32karakter

# -------------------------------------------------------
# COTURN (TURN Server)
# -------------------------------------------------------
TURN_HOST=coturn
TURN_PORT=3478
TURN_USERNAME=meetapp
TURN_PASSWORD=turnpass

# -------------------------------------------------------
# BACKEND API
# -------------------------------------------------------
API_PORT=3000
JWT_SECRET=jwt_secret_panjang_minimal_32karakter
JWT_EXPIRES_IN=7d

# -------------------------------------------------------
# FRONTEND
# -------------------------------------------------------
VITE_API_BASE_URL=http://localhost
VITE_LIVEKIT_URL=ws://localhost:7880
