# =============================================================
# services/api/Dockerfile.dev — Development (hot-reload)
# =============================================================
FROM node:20-alpine

WORKDIR /app

# Install dependencies (termasuk devDependencies untuk tsx)
COPY package*.json ./
RUN npm install

# Copy source
COPY . .

EXPOSE 3000

# tsx watch untuk hot-reload
CMD ["npm", "run", "dev"]
